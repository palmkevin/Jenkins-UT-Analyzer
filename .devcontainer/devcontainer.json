{
  "name": "Jenkins-UT-Analyzer",
  "dockerComposeFile": ["../docker-compose.yml", "docker-compose.dev.yml"],
  "service": "dev",
  "workspaceFolder": "/workspaces/Jenkins-UT-Analyzer",

  // Only `db` auto-starts with the `dev` service; web/poller/migrate stay down for a fast inner loop.
  "runServices": ["db"],

  "features": {
    // Installs the docker CLI + compose plugin and binds the VM's /var/run/docker.sock, so
    // `docker compose up` from inside the container drives the VM daemon (the full prod-like stack).
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
    // Installs the Claude Code CLI in the container (native binary, on PATH) + registers the
    // extension. The VS Code panel bundles its own CLI, but this makes `claude` work in the
    // integrated terminal too. Auto-updates by default.
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {},
    // Installs the GitHub CLI (`gh`) into the image so PRs / branch-protection can be driven from
    // the terminal. Binary only — `gh` has its own auth store (not git's credential helper), so
    // authenticate once per persisted home with `gh auth login`.
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  // Persist Claude Code's login/settings/history across container rebuilds. The base image runs as
  // user `vscode` (home /home/vscode); without this, ~/.claude is discarded and you re-sign-in each
  // rebuild. First run: `claude` in a terminal to authenticate (browser flow).
  // Second volume: `gh` keeps its auth token in ~/.config/gh (its own store, not git's), which would
  // otherwise be discarded on rebuild — persist it so `gh auth login` is a one-time step.
  "mounts": [
    "source=claude-code-config,target=/home/vscode/.claude,type=volume",
    "source=gh-config,target=/home/vscode/.config/gh,type=volume"
  ],

  "remoteEnv": { "TZ": "Europe/Luxembourg" },

  // 8000 = in-container `uvicorn --reload`; 8088 = the compose `web` service's published WEB_PORT.
  "forwardPorts": [8000, 8088],

  // First: rewrite git's github SSH URLs to HTTPS *container-locally* (~/.gitconfig, not the
  // bind-mounted .git) so plain git push/fetch use VS Code's forwarded HTTPS credential helper —
  // the container has no forwarded SSH agent. The repo's origin stays SSH, so the host is unaffected.
  // Then match CI's install exactly (.github/workflows/ci.yml) and bring the schema to head vs `db`.
  "postCreateCommand": "git config --global url.https://github.com/.insteadOf git@github.com: && pip install -e '.[dev]' && uta migrate",

  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "charliermarsh.ruff"],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "[python]": { "editor.defaultFormatter": "charliermarsh.ruff" }
      }
    }
  }
}
