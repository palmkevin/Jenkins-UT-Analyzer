# ── Jenkins (read access; anonymous read works, token optional) ────────────────
JENKINS_BASE_URL=https://jenkins2.labsolution.lu
JENKINS_JOB_PATH=job/Development/view/Build/job/lsdevbuild-build-release-permanent
JENKINS_USER=
JENKINS_API_TOKEN=
EXPECTED_SHARDS=2

# ── Oracle ut_ref (read-only; data-change correlation) ─────────────────────────
UT_REF_HOST=lsdb04
UT_REF_PORT=1521
UT_REF_SERVICE=lsdb04pdb
UT_REF_USER=utestref01
UT_REF_PASSWORD=
# oracledb thin mode by default; set true only if a thick client / wallet is required
UT_REF_THICK=false

# ── PostgreSQL (app store) ─────────────────────────────────────────────────────
# Dev: the compose `db` service. Prod-later: point at the external server, same URL shape.
DATABASE_URL=postgresql+psycopg://uta:uta@db:5432/uta
# Used by the compose `db` service to initialize the container:
POSTGRES_USER=uta
POSTGRES_PASSWORD=uta
POSTGRES_DB=uta

# ── Email (regression-only alert) ──────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=25
SMTP_FROM=
SMTP_RECIPIENTS=
SMTP_USER=
SMTP_PASSWORD=
EMAIL_RECOVERY_NOTICE=false

# ── App ────────────────────────────────────────────────────────────────────────
APP_DEFAULT_ACTOR=test-user
# Tuning (defaults; refine on real data)
FLAKY_TRANSITION_THRESHOLD=0.3
PGTRGM_SIMILARITY_CUTOFF=0.3

# ── Ingest / correlation windows ────────────────────────────────────────────────
# Data changes precede the nightly run, so look back before the run start; the tolerance margin
# (B1) widens both ends to absorb Jenkins↔Oracle clock skew.
DATA_CHANGE_LOOKBACK_HOURS=12
DATA_CHANGE_TOLERANCE_MINUTES=5
# Scheduled-poll cadence (seconds) for `uta poll`.
POLL_INTERVAL_SECONDS=300
