# ── Jenkins (read access; anonymous read works, token optional) ────────────────
JENKINS_BASE_URL=https://jenkins2.labsolution.lu
JENKINS_JOB_PATH=job/Development/view/Build/job/lsdevbuild-build-release-permanent
JENKINS_USER=
JENKINS_API_TOKEN=
# TLS verification is on by default. Only set false as a stopgap for an internal CA the host
# doesn't trust yet — prefer JENKINS_CA_BUNDLE below instead.
JENKINS_VERIFY_TLS=true
# Path to a CA bundle (PEM) to verify Jenkins' cert against, e.g. an internal CA. Takes precedence
# over JENKINS_VERIFY_TLS when set (verification stays on, against this bundle).
JENKINS_CA_BUNDLE=
EXPECTED_SHARDS=2
# Also ingest the unittest console-log UT stages (parsed from each stage's wfapi/log). The suites
# are the stage names without the " - <track>" suffix; only these are treated as test stages.
INGEST_UNITTEST_STAGES=true
UNITTEST_SUITES=LXS,SMB Pricing,SMB Transform,ITF Highlevel,Uniface deploy unit tests

# ── Oracle ut_ref (read-only; data-change correlation) ─────────────────────────
UT_REF_HOST=lsdb04
UT_REF_PORT=1521
UT_REF_SERVICE=lsdb04pdb
UT_REF_USER=utestref01
UT_REF_PASSWORD=
# oracledb thin mode by default; set true only if a thick client / wallet is required
UT_REF_THICK=false

# ── PostgreSQL (app store) ─────────────────────────────────────────────────────
# Dev: the compose `db` service. Prod-later: point at the external server, same URL shape.
DATABASE_URL=postgresql+psycopg://uta:uta@db:5432/uta
# Used by the compose `db` service to initialize the container:
POSTGRES_USER=uta
POSTGRES_PASSWORD=uta
POSTGRES_DB=uta

# ── Email (regression-only alert) ──────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=25
SMTP_FROM=
SMTP_RECIPIENTS=
SMTP_USER=
SMTP_PASSWORD=
EMAIL_RECOVERY_NOTICE=false

# ── App ────────────────────────────────────────────────────────────────────────
# Host port the compose `web` service publishes (container always listens on 8000).
WEB_PORT=8088
APP_DEFAULT_ACTOR=test-user
# Tuning (defaults; refine on real data)
FLAKY_TRANSITION_THRESHOLD=0.3
# Oscillation window (days) for the flaky score and failure-history counts.
FLAKY_WINDOW_DAYS=30
PGTRGM_SIMILARITY_CUTOFF=0.3
# Similar past cases surfaced per failure by the knowledge base.
KB_TOP_K=5
# How long a fixed test stays in the "recently fixed" bucket.
RECENTLY_FIXED_DAYS=7
# Max test rows rendered per dashboard section before it is capped behind a "Load all N Tests"
# link (keeps long lists responsive). 0 disables the cap.
UI_ROW_LIMIT=50
# Cold-start back-fill: on a fresh (empty) store, ingest the last N completed builds oldest-first
# (age N → age 1) before incremental polling takes over. Also the default depth for `uta bootstrap`.
BACKFILL_DEPTH=10

# ── External deep links (surfaced in the UI) ──────────────────────────────────────
# Jira base for episode ticket links: {JIRA_BASE_URL}/browse/<TICKET>.
JIRA_BASE_URL=https://labsolution.atlassian.net
# FishEye changelog for SVN revisions: {FISHEYE_CHANGELOG_URL}?cs=<revision>.
FISHEYE_CHANGELOG_URL=https://fisheye.labsolution.lu/changelog/LS_TRUNK
# ZEPHYR (Kanoah) test-case deep link: {ZEPHYR_TEST_CASE_URL_PREFIX}<LX-T…>.
ZEPHYR_TEST_CASE_URL_PREFIX=https://labsolution.atlassian.net/projects/LX?selectedItem=com.atlassian.plugins.atlassian-connect-plugin:com.kanoah.test-manager__main-project-page#!/v2/testCase/

# ── LLM hypothesis ─────────────────────────────────────────────────────────────────
# Provider: "anthropic", "openai", or empty to auto-pick from whichever key is set below (Anthropic
# wins if both). With no key the deterministic predicted cause still works; llm_hypothesis stays
# blank. Only the live `uta poll` path calls the model; back-fill never does.
LLM_PROVIDER=
# Anthropic Developer Console key (pay-as-you-go, separate from any Claude.ai subscription).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# OpenAI Platform key (platform.openai.com, pay-as-you-go, separate from a ChatGPT subscription).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Ingest / correlation windows ────────────────────────────────────────────────
# Data changes precede the nightly run, so look back before the run start; the tolerance margin
# (B1) widens both ends to absorb Jenkins↔Oracle clock skew.
DATA_CHANGE_LOOKBACK_HOURS=12
DATA_CHANGE_TOLERANCE_MINUTES=5
# Scheduled-poll cadence (seconds) for `uta poll`.
POLL_INTERVAL_SECONDS=300
